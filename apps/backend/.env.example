ENV=dev
API_NAME=WonKey API
API_VERSION=0.1.0

SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DEFAULT_ORG_ID=your_default_org_uuid_here
DEV_DISABLE_ORG_MEMBERSHIP_CHECKS=false
API_KEY_HMAC_SECRET=your_long_random_hmac_secret_here
API_KEY_PEPPER=your_server_side_pepper_here

REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
ADMIN_API_KEY=your_server_side_admin_key_here

RATE_LIMIT_DEFAULT_RPM=60
RATE_LIMIT_WINDOW_SECONDS=60
API_KEY_AUTH_EXEMPT_PATHS=/health,/health/redis,/docs,/redoc,/openapi.json
RATE_LIMIT_EXEMPT_PATHS=/health,/health/redis,/docs,/redoc,/openapi.json
REQUEST_LOG_EXEMPT_PATHS=/health,/health/redis,/docs,/redoc,/openapi.json
REQUEST_LOG_SAMPLE_EVERY_N=1
LOGS_DEFAULT_LIMIT=100
LOGS_MAX_LIMIT=500
