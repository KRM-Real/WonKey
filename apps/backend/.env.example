ENV=dev
API_NAME=WonKey API
API_VERSION=0.1.0

SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DEFAULT_ORG_ID=your_default_org_uuid_here
API_KEY_HMAC_SECRET=your_long_random_hmac_secret_here

REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_DEFAULT_RPM=60
RATE_LIMIT_WINDOW_SECONDS=60
API_KEY_AUTH_EXEMPT_PATHS=/health,/health/redis,/debug/env,/docs,/redoc,/openapi.json
RATE_LIMIT_EXEMPT_PATHS=/health,/health/redis,/debug/env,/docs,/redoc,/openapi.json
